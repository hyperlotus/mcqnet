# Whitelist mode: ignore everything at the repository root by default.
/*

# Keep project sources and root metadata visible to Git.
!/.clang-format
!/.clang-tidy
!/.clangd
!/.gitignore
!/LICENSE
!/README.md
!/lib/
!/lib/**
!/mcqnet/
!/mcqnet/**
!/xmake.lua

# Ignore editor and OS temp files anywhere in the tree.
.DS_Store
*.swp
*.swo
*~
